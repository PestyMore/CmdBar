{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CmdBar",
  "version": "1.1.0",
  "identifier": "com.PestyMore.cmdbar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "CmdBar",
        "width": 800,
        "height": 450,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "PestyMore",
    "copyright": "Copyright © 2024 PestyMore",
    "shortDescription": "A Glassmorphism Quick Launcher"
  }
}